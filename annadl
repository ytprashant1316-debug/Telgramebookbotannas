#! /usr/bin/env python3
import time
import os
import re
import sys
import argparse
import json
import urllib.request
from pathlib import Path
from html.parser import HTMLParser
from urllib.parse import urljoin

from cloakbrowser import launch

# ---------------------------------------------------------------------------
# Domain auto-discovery
# ---------------------------------------------------------------------------
DOMAIN_SOURCE = "https://shadowlibraries.github.io/DirectDownloads/AnnasArchive/"
FALLBACK_DOMAINS = [
    "https://annas-archive.gl",
    "https://annas-archive.pk",
    "https://annas-archive.gd",
    "https://annas-archive.org",
]

LIBGEN_SOURCE = "https://shadowlibraries.github.io/DirectDownloads/libgen/"
LIBGEN_FALLBACK_DOMAINS = [
    "http://libgen.li",
    "http://libgen.vg",
    "http://libgen.la",
    "http://libgen.bz",
    "http://libgen.gl",
]


class _LinkParser(HTMLParser):
    """Minimal HTML parser to extract href values."""
    def __init__(self):
        super().__init__()
        self.links = []

    def handle_starttag(self, tag, attrs):
        if tag == "a":
            for name, value in attrs:
                if name == "href" and value:
                    self.links.append(value)


def _fetch_domains_from_source() -> list:
    """Scrape candidate Anna's Archive domains from the shadow-libraries tracker."""
    try:
        req = urllib.request.Request(
            DOMAIN_SOURCE,
            headers={"User-Agent": "Mozilla/5.0 (compatible; annadl/1.0)"},
        )
        with urllib.request.urlopen(req, timeout=10) as resp:
            html = resp.read().decode("utf-8", errors="replace")

        parser = _LinkParser()
        parser.feed(html)

        domains = []
        for href in parser.links:
            href = href.split("?")[0].rstrip("/")
            if "annas-archive" in href and "shadowlibraries" not in href and href.startswith("http"):
                if href not in domains:
                    domains.append(href)
        return domains if domains else FALLBACK_DOMAINS
    except Exception as e:
        print(f"[domain] Could not fetch domain list: {e} — using fallbacks")
        return FALLBACK_DOMAINS


def _test_domain(domain: str) -> bool:
    """Return True if the domain resolves and returns HTTP 200/30x."""
    try:
        req = urllib.request.Request(
            domain + "/",
            headers={"User-Agent": "Mozilla/5.0 (compatible; annadl/1.0)"},
        )
        with urllib.request.urlopen(req, timeout=8) as resp:
            return resp.status < 400
    except Exception:
        return False


def get_active_domain(config_path: str) -> str:
    """
    1. Try the domain cached in config.json first.
    2. If that fails, fetch fresh candidates from the shadow-libraries tracker.
    3. Test each candidate, return the first that responds.
    4. Save the working domain back to config.json.
    """
    cfg = {}
    if Path(config_path).is_file():
        try:
            with open(config_path) as f:
                cfg = json.load(f)
        except Exception:
            pass

    cached = cfg.get("base_url", "").rstrip("/")
    if cached and _test_domain(cached):
        print(f"[domain] Using cached domain: {cached}")
        return cached

    print("[domain] Fetching active domains from shadow-libraries tracker...")
    candidates = _fetch_domains_from_source()
    print(f"[domain] Candidates: {candidates}")

    for domain in candidates:
        print(f"[domain] Testing {domain} ...", end=" ", flush=True)
        if _test_domain(domain):
            print("OK")
            cfg["base_url"] = domain
            try:
                with open(config_path, "w") as f:
                    json.dump(cfg, f, indent=2)
            except Exception:
                pass
            return domain
        print("failed")

    print("[domain] WARNING: No domain responded. Using first fallback anyway.")
    return FALLBACK_DOMAINS[0]


def get_active_libgen_domain(config_path: str) -> str:
    """Fetch and cache the active libgen domain from shadow-libraries tracker."""
    cfg = {}
    if Path(config_path).is_file():
        try:
            with open(config_path) as f:
                cfg = json.load(f)
        except Exception:
            pass

    cached = cfg.get("libgen_base_url", "").rstrip("/")
    if cached and _test_domain(cached):
        return cached

    print("[libgen] Fetching active libgen domains from shadow-libraries tracker...")
    try:
        req = urllib.request.Request(
            LIBGEN_SOURCE,
            headers={"User-Agent": "Mozilla/5.0 (compatible; annadl/1.0)"},
        )
        with urllib.request.urlopen(req, timeout=10) as resp:
            html = resp.read().decode("utf-8", errors="replace")
        parser = _LinkParser()
        parser.feed(html)
        candidates = []
        for href in parser.links:
            href = href.split("?")[0].rstrip("/")
            if "libgen" in href and "shadowlibraries" not in href and href.startswith("http"):
                if href not in candidates:
                    candidates.append(href)
        if not candidates:
            candidates = LIBGEN_FALLBACK_DOMAINS
    except Exception as e:
        print(f"[libgen] Could not fetch domain list: {e} — using fallbacks")
        candidates = LIBGEN_FALLBACK_DOMAINS

    print(f"[libgen] Candidates: {candidates}")
    for domain in candidates:
        print(f"[libgen] Testing {domain} ...", end=" ", flush=True)
        if _test_domain(domain):
            print("OK")
            cfg["libgen_base_url"] = domain
            try:
                with open(config_path, "w") as f:
                    json.dump(cfg, f, indent=2)
            except Exception:
                pass
            return domain
        print("failed")

    return LIBGEN_FALLBACK_DOMAINS[0]


# ---------------------------------------------------------------------------
# Config / paths
# ---------------------------------------------------------------------------
C_DIR = os.path.dirname(os.path.realpath(__file__))
CONFIG_PATH = os.path.join(C_DIR, 'config.json')
DL_PATH = os.path.join(C_DIR, 'assets')

if Path(CONFIG_PATH).is_file():
    with open(CONFIG_PATH, 'r') as f:
        config = json.load(f)
        if config.get('download_path', ''):
            DL_PATH = config['download_path'].strip()

# ---------------------------------------------------------------------------
# Args
# ---------------------------------------------------------------------------
parser = argparse.ArgumentParser()
parser.add_argument('path', metavar='path', type=str, default=DL_PATH, action='store',
                    nargs='?', help='A path for the download')
parser.add_argument('--s', metavar='search', type=str, action='store',
                    required=True, help='A search query for the download')
parser.add_argument('--n', metavar='quantity', type=int, default=5,
                    help='Number of search results desired')
args = parser.parse_args()

DL_PATH = args.path
search = args.s
result_count = args.n

os.makedirs(DL_PATH, exist_ok=True)

BASE_URL = get_active_domain(CONFIG_PATH)
print(f"[domain] Active base URL: {BASE_URL}")

LIBGEN_BASE = get_active_libgen_domain(CONFIG_PATH)
print(f"[libgen] Active libgen URL: {LIBGEN_BASE}")

# ---------------------------------------------------------------------------
# Browser
# ---------------------------------------------------------------------------
browser = launch(headless=True)
context = browser.new_context(accept_downloads=True)
page = context.new_page()

sresults = []

start_url = f"{BASE_URL}/search?q={search}"
page.goto(start_url, wait_until="domcontentloaded")
page.wait_for_timeout(2000)
page.evaluate("window.scrollTo(0, document.body.scrollHeight)")
page.wait_for_timeout(1000)

book_links = page.query_selector_all('a.js-vim-focus.custom-a')
print(f"Found {len(book_links)} book links")

if len(book_links) < result_count:
    result_count = len(book_links)
    print(f"Only {result_count} results found")

if result_count == 0:
    print("No results found. Please check your search query.")
    browser.close()
    sys.exit(1)

for n in range(result_count):
    href = str(book_links[n].get_attribute('href'))
    if href and not href.startswith('http'):
        href = BASE_URL + href
    sresults.append(href)

# ---------------------------------------------------------------------------
# Display results
# ---------------------------------------------------------------------------
for i in range(result_count):
    try:
        book_link = book_links[i]
        title = (book_link.inner_text() or "").strip()

        container = book_link
        try:
            for _ in range(5):
                container = container.evaluate_handle("el => el.parentElement")
                classes = container.get_attribute('class') or ""
                if 'flex' in classes and ('pt-3' in classes or 'border-b' in classes):
                    break
        except Exception:
            pass

        print(f"\n[{i+1}] {title}")

        all_text = container.inner_text() if container else ""

        author = "Unknown"
        try:
            all_links_in_container = container.query_selector_all('a')
            for link in all_links_in_container:
                href_val = link.get_attribute('href') or ""
                text = (link.inner_text() or "").strip()
                if href_val and 'search?q=' in href_val and text and text != title:
                    if len(text.split(',')) <= 2 and len(text.split()) <= 4:
                        author = text
                        break
        except Exception as e:
            print(f"\t  Error extracting author: {e}")

        print(f"\tAuthor: {author}")

        publisher = "Unknown"
        try:
            year_match = re.search(r'\b(19|20)\d{2}\b', all_text)
            if year_match:
                publisher = year_match.group(0)
        except Exception as e:
            print(f"\t  Error extracting year: {e}")

        print(f"\tYear: {publisher}")

        language = "Unknown"
        file_format = "Unknown"
        file_size = "Unknown"

        try:
            language_match = re.search(r'(\w+)\s+\[([a-z]{2})\]', all_text)
            if language_match:
                language = language_match.group(1)

            format_match = re.search(r'\b(EPUB|PDF|MOBI|AZW3|TXT|DOC|DOCX)\b', all_text, re.IGNORECASE)
            if format_match:
                file_format = format_match.group(1).upper()

            size_match = re.search(r'(\d+\.?\d*\s*[MKG]B)', all_text, re.IGNORECASE)
            if size_match:
                file_size = size_match.group(1)

        except Exception as e:
            print(f"\t  Error extracting metadata: {e}")

        print(f"\tLanguage: {language}")
        print(f"\tFormat: {file_format}, Size: {file_size}")

        if i == 0:
            print(f"\t  Debug - Container text preview: {all_text[:200]}...")

    except Exception as e:
        print(f"\n[{i+1}] Error extracting info for book {i+1}: {e}")
        try:
            title = (book_links[i].inner_text() or "").strip()
            print(f"\tTitle: {title}")
        except Exception:
            print(f"\tCould not extract title")

# ---------------------------------------------------------------------------
# Download
# ---------------------------------------------------------------------------
try:
    book_selection = int(input("\nEnter desired download: "))

    if book_selection < 1 or book_selection > len(sresults):
        print("Invalid selection")
        browser.close()
        sys.exit(1)

    book_page = context.new_page()
    book_page.goto(sresults[book_selection - 1], wait_until="domcontentloaded")
    book_page.wait_for_timeout(2000)

    # Click "show external downloads" if present
    for selector in [
        "text=show external downloads",
        "text=external downloads",
        "button:has-text('show external downloads')",
    ]:
        try:
            link_el = book_page.query_selector(selector)
            if link_el:
                link_el.click()
                break
        except Exception:
            pass

    book_page.wait_for_timeout(2000)

    page_text = book_page.inner_text("body").lower()

    # ------------------------------------------------------------------
    # Step 2: Extract MD5 from the book URL for direct libgen construction
    # ------------------------------------------------------------------
    book_url = sresults[book_selection - 1]
    md5_match = re.search(r'/md5/([a-fA-F0-9]{32})', book_url)
    md5 = md5_match.group(1) if md5_match else None

    if 'libgen' in page_text or md5:
        try:
            # Build libgen ads page URL directly from MD5 and active domain
            if md5:
                libgen_link = f"{LIBGEN_BASE}/ads.php?md5={md5}"
                print(f"  Built libgen URL: {libgen_link}")
            else:
                # Fall back to extracting from page
                libgen_link = None
                for sel in ["a.js-download-link[href*='libgen']", "a[href*='libgen']"]:
                    el = book_page.query_selector(sel)
                    if el:
                        href_val = el.get_attribute('href') or ""
                        if href_val:
                            libgen_link = href_val if href_val.startswith('http') else urljoin(BASE_URL, href_val)
                            break
                if not libgen_link:
                    raise Exception("Could not find libgen link and no MD5 available")

            # Fetch ads.php with urllib (plain HTTP) to extract the get.php?md5=...&key=... link.
            # Using the browser here often gets blocked/redirected before the real content loads.
            print("Fetching libgen ads page via urllib ...")
            direct_dl_href = None
            try:
                _req = urllib.request.Request(
                    libgen_link,
                    headers={"User-Agent": "Mozilla/5.0 (compatible; annadl/1.0)"},
                )
                with urllib.request.urlopen(_req, timeout=15) as _resp:
                    _html = _resp.read().decode("utf-8", errors="replace")

                # Parse out get.php?md5=...&key=... using regex (faster than HTML parser)
                _get_match = re.search(r'href=[^>]*?(get\.php\?md5=[^\"\'> ]+)', _html)
                if _get_match:
                    _get_path = _get_match.group(1)
                    direct_dl_href = _get_path if _get_path.startswith('http') else urljoin(libgen_link, _get_path)
                    print(f"  [libgen] Found GET link: {direct_dl_href}")
                else:
                    # Fallback: dump a snippet for debugging
                    _snippet = _html[_html.find('<table'):_html.find('<table') + 500] if '<table' in _html else _html[:500]
                    print(f"  [debug] ads.php snippet:\n{_snippet}")
                    raise Exception("get.php link not found in ads.php response")
            except Exception as _e:
                raise Exception(f"urllib fetch of ads.php failed: {_e}")



            print(f"  Direct link: {direct_dl_href}")

            # get.php responds with a direct file stream — the browser aborts the page
            # navigation (ERR_ABORTED) but still triggers a download event.
            # Use urllib to stream the file directly instead, which is simpler and reliable.
            print("Downloading file via urllib ...")
            _dl_req = urllib.request.Request(
                direct_dl_href,
                headers={"User-Agent": "Mozilla/5.0 (compatible; annadl/1.0)"},
            )
            with urllib.request.urlopen(_dl_req, timeout=180) as _dl_resp:
                # Derive filename from Content-Disposition or URL
                _cd = _dl_resp.headers.get("Content-Disposition", "")
                _fname_match = re.search(r'filename[^;=\n]*=[ ]*["\']?([^"\';\n]+)', _cd)
                if _fname_match:
                    _fname = _fname_match.group(1).strip().strip('"').strip("'")
                else:
                    _fname = direct_dl_href.split("?")[0].rstrip("/").split("/")[-1] or "download"
                dest = os.path.join(DL_PATH, _fname)
                with open(dest, "wb") as _out:
                    while True:
                        _chunk = _dl_resp.read(65536)
                        if not _chunk:
                            break
                        _out.write(_chunk)
            print(f"Successfully downloaded: {dest}")

        except Exception as e:
            print(f"Error with libgen download: {e}")
            print("Falling back to manual link selection...")

    if 'libgen' not in page_text and not md5:
        print("ERROR: libgen.li link not found or failed.")
        print("The following links require human verification.")
        book_page.wait_for_timeout(2000)

        try:
            download_elements = book_page.query_selector_all('a.js-download-link')
            if not download_elements:
                download_elements = book_page.query_selector_all('a[href*="download"]')
            if not download_elements:
                download_elements = book_page.query_selector_all(
                    "a[href*='libgen'], a[href*='download'], a[href*='mirror']"
                )

            for idx, el in enumerate(download_elements, start=1):
                try:
                    link_text = (el.inner_text() or "").strip()
                    link_href = el.get_attribute('href')
                    parent_text = ""
                    try:
                        parent = el.evaluate_handle("el => el.parentElement")
                        parent_text = (parent.inner_text() or "").strip()
                    except Exception:
                        pass

                    print(f"\nOption {idx}:")
                    print(f"\tLink Text: {link_text}")
                    print(f"\tLink Href: {link_href}")
                    if parent_text and parent_text != link_text:
                        print(f"\tContext: {parent_text}")
                except Exception as e:
                    print(f"\nOption {idx}: Error extracting link info - {e}")

        except Exception as e:
            print(f"Could not find download links: {e}")

except KeyboardInterrupt:
    print("\nScript interrupted by user")
except Exception as e:
    print(f"An error occurred: {e}")
finally:
    browser.close()